# --- Consolidated .gitignore ---

# Environment & Secrets — NEVER commit these
.env
.env.local
.env.*.local
*.local

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python / ML
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# ML Artifacts — transient, should not be version-controlled
outputs/
backend-ml/outputs/
outputs/*.pkl
outputs/*.png
outputs/*.csv
outputs/*.joblib
temp.csv
temp*.csv
backend-ml/temp.csv
backend-ml/temp*.csv

# ChromaDB vector store — contains user data, must not be committed (M2 fix)
vector_db/
backend-ml/vector_db/

# Dataset files — never commit user data or sample data (M6 fix)
data/*.csv
backend-ml/data/*.csv

# Build & Bundles
dist/
dist-ssr/
build/
.next/
out/
bin/
obj/

# Uploads (temp user files)
uploads/
backend/uploads/

# Logs & Temp
*.log
logs/
temp/
tmp/

# Test & Debug files — remove from tracking (M4 fix)
backend/test_*.js
backend/full_error.txt
backend/test_output.txt
backend/check_models.js
backend/list_models.js
backend/list_raw_models.js
backend/capture_error.js
backend-ml/test*.py
backend-ml/check_memory.py
backend-ml/notebooks/

# Editor / OS
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?