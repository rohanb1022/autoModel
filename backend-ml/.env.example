# AutoModel ML Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env to Git.

# ---- LLM Configuration ----
# Set to "true" only for local development with Ollama installed.
# On cloud deployments, keep this as "false".
USE_OLLAMA=false

# ---- API Keys ----
# [PRIMARY LLM] Groq API Key — open-source Gemma/Llama models, 15,000 TPM free tier
# Used for: RAG chatbot, AI insights
# Get yours FREE at: https://console.groq.com  (takes 30 seconds, no credit card)
GROQ_API_KEY=your_groq_api_key_here

# [VISION LLM] Google Gemini API Key — used ONLY for visualization chart image analysis
# (Groq does not support image input yet, so Gemini handles this one route)
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY_2=your_gemini_api_key_here

# [FALLBACK LLM] HuggingFace API token — Phi-3-mini, triggers if Groq is rate-limited
# No hard RPM cap (queued) — ensures zero user-facing 429 errors
# Get yours at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hf_token_here

# ---- Auth ----
# JWT secret must match the one in the Node.js backend exactly
JWT_SECRET=your_jwt_secret_here

# ---- ChromaDB / Telemetry ----
ANONYMIZED_TELEMETRY=False
CHROMA_TELEMETRY=False
