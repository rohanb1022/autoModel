# AutoModel Frontend — Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit your actual .env.local to Git.

# ---- Backend API URLs ----
# These are only needed if you want to override the auto-detection in urls.ts
# By default, urls.ts auto-detects local vs production based on window.location.hostname

# Node.js backend URL (used in production)
VITE_BACKEND_URL=https://your-node-backend.onrender.com

# ML backend URL (used in production)
VITE_ML_BACKEND_URL=https://your-ml-space.hf.space
