# AutoModel Node.js Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env to Git.

# ---- Database ----
# MongoDB connection string (MongoDB Atlas recommended)
# Get yours at: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ---- Server ----
PORT=5000
NODE_ENV=production

# ---- CORS ----
# Your deployed Vercel frontend URL (e.g. https://automodel.vercel.app)
FRONTEND_URL=https://your-project.vercel.app

# ---- Auth ----
# Must match JWT_SECRET in the ML backend exactly
JWT_SECRET=your_jwt_secret_here

# ---- Gemini AI ----
# Google Gemini API Key (used for auto-healer in this backend)
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here

# ---- Razorpay (Payment) ----
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
